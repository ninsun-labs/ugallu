{
  "title": "ugallu / audit-detection",
  "uid": "ugallu-audit-detection",
  "schemaVersion": 39,
  "refresh": "30s",
  "tags": ["ugallu", "wave2", "audit-detection"],
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active SigmaRules",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "count by (rule) (ugallu_audit_rule_matches_total)", "legendFormat": "rules" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Audit events ingested (per source)",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "targets": [
        { "expr": "rate(ugallu_audit_file_lines_total[5m])", "legendFormat": "file" },
        { "expr": "rate(ugallu_audit_webhook_events_total[5m])", "legendFormat": "webhook" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Source parse errors",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "rate(ugallu_audit_file_parse_errors_total[5m])", "legendFormat": "file parse" },
        { "expr": "rate(ugallu_audit_webhook_parse_errors_total[5m])", "legendFormat": "webhook parse" },
        { "expr": "rate(ugallu_audit_webhook_auth_failures_total[5m])", "legendFormat": "webhook auth" },
        { "expr": "rate(ugallu_audit_webhook_backpressure_total[5m])", "legendFormat": "webhook 503" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Rule matches (per rule)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum by (rule) (rate(ugallu_audit_rule_matches_total[5m]))", "legendFormat": "{{rule}}" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Rate-limit drops + emit errors (per rule)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum by (rule) (rate(ugallu_audit_rule_dropped_total[5m]))", "legendFormat": "drop {{rule}}" },
        { "expr": "sum by (rule) (rate(ugallu_audit_rule_emit_errors_total[5m]))", "legendFormat": "emit-err {{rule}}" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "SE emitter (cross-component)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        { "expr": "sum by (class) (rate(ugallu_emitter_emitted_total[5m]))", "legendFormat": "emitted {{class}}" },
        { "expr": "sum by (reason) (rate(ugallu_emitter_dropped_total[5m]))", "legendFormat": "dropped {{reason}}" },
        { "expr": "ugallu_emitter_buffer_depth", "legendFormat": "buffer depth" }
      ]
    }
  ]
}
